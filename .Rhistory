gex = Seurat::GetAssayData(Input_Seurat@assays[["RNA"]],layer = 'counts')
adt = Seurat::GetAssayData(Input_Seurat@assays[["ADT"]],layer = 'counts')
#Train test split
indx <- sample(1:ncol(Input_Seurat), size = ncol(Input_Seurat), replace = FALSE)
train_cols <- colnames(Input_Seurat)[indx[1:floor(0.75*ncol(Input_Seurat))]]
test_cols <- colnames(Input_Seurat)[indx[(floor(0.75*ncol(Input_Seurat))+1):ncol(Input_Seurat)]]
# Wrapping the matrix in brackets prevents Rstudios autocomplete from nuking the entire session
# when editing the index
gex_train <- (gex)[,train_cols]
gex_test <- (gex)[,test_cols]
adt_train <- (adt)[,train_cols]
adt_test <- (adt)[,test_cols]
train_model <- fit_predictor(gex_train,adt_train,gexp_test = gex_test)
ev <- evaluate_predictor(train_model,gex_test,adt_test)
# test_predictions <- predict(train_model,gex_test)
# adt_test[adt_test == 0] <- 0.99
# reference <- Matrix::Matrix((t(compositions::clr(t(as.matrix(adt_test))))),sparse = TRUE)
full_model <- fit_predictor(gex,adt,reused_tsvd = train_model$tsvd_v)
saveRDS(full_model,paste0('Intermediate_files_R_Python/Trained_ADT_prediction_models/',dataset_name,'_based_ADT_prediction_model'))
rm(list=ls())
