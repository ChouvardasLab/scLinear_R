set.seed(50)
#Name / prefix used for intermediate / output files
dataset_name <- '3Tissue_kbl'
files <- dir('ADT_prediction_training_data/Three_tissue_input_data/',full.names = TRUE)
# dataset_name <- '10x_PBMC_mixed_prot'
# files <- c('ADT_prediction_training_data/10x_intracellular_extracellular_prot_data/80k_Human_PBMCs_PTG_MultiproPanel_IC_4plex_PBMC_BC2_AB2_Rested_count_sample_filtered_feature_bc_matrix.h5')
# dataset_name <- '10x_DTC_PBMC_lung_kidney_mixed_prot'
# files <- dir('ADT_prediction_training_data/10x_Intracellular_extracellular_prot_lung_kidney/',full.names = TRUE)
annotation_level <- 1
for(file_n in 1:length(files)){
file <- files[file_n]
data_source <- paste0('Input_',file_n)
data <- Seurat::Read10X_h5(file)
gex <- data$`Gene Expression`
adt <- data$`Antibody Capture`
combi_seurat <- Seurat::CreateSeuratObject(counts = gex, assay = 'RNA')
adt_seurat <- Seurat:: CreateAssayObject(counts = adt)
combi_seurat[["ADT"]] <- adt_seurat
assign(data_source,combi_seurat)
rm(adt,adt_seurat,combi_seurat,data,gex)
}
total_cells <- 0
datasets_parts <- ls(pattern = 'Input_')
for(ds in datasets_parts){
total_cells <- total_cells + ncol(get0(ds))
}
#Preprocessing & normalization takes ages for large datasets
#Many steps scale quadratically / higher order with data size
#Cut to 40k cells & sample an equal amount from each subdataset
if(total_cells > 40000){
per_dataset_part <- floor(40000/length(datasets_parts))
for(ds in datasets_parts){
keep <- sample(colnames(get0(ds)),min(per_dataset_part,length(colnames(get0(ds)))),replace = FALSE)
assign(ds,get0(ds)[,keep])
}
}
if(length(ls(pattern = 'Input_')) > 1){
Input_Seurat <- merge(Input_1,y = lapply(setdiff(ls(pattern = 'Input_'),'Input_1'),get0),
add.cell.ids = ls(pattern = 'Input_'), project = dataset_name)
}else{Input_Seurat <- Input_1}
rm(list = ls(pattern = 'Input_[0-9]'))
Input_Seurat <- SeuratObject::JoinLayers(Input_Seurat)
Input_Seurat <- prepare_data(Input_Seurat,anno_level = annotation_level)
gex = Seurat::GetAssayData(Input_Seurat@assays[["RNA"]],layer = 'counts')
adt = Seurat::GetAssayData(Input_Seurat@assays[["ADT"]],layer = 'counts')
#Train test split
indx <- sample(1:ncol(Input_Seurat), size = ncol(Input_Seurat), replace = FALSE)
train_cols <- colnames(Input_Seurat)[indx[1:floor(0.75*ncol(Input_Seurat))]]
test_cols <- colnames(Input_Seurat)[indx[(floor(0.75*ncol(Input_Seurat))+1):ncol(Input_Seurat)]]
# Wrapping the matrix in brackets prevents Rstudios autocomplete from nuking the entire session
# when editing the index
gex_train <- (gex)[,train_cols]
gex_test <- (gex)[,test_cols]
adt_train <- (adt)[,train_cols]
adt_test <- (adt)[,test_cols]
# full_model <- fit_predictor(gex,adt)
gex_norm <- gexp_normalize(gex)
data_panos <- readRDS('Bladder_seurat_from_Panos/annotated_seurat.rds')
data_panos_gex <- Seurat::GetAssayData(data_panos@assays$RNA,layer = 'counts')
data_panos_gex <- (data_panos_gex)[,sample(colnames(data_panos_gex),20000)]
data_panos_gex <- match_genesets(gex_norm,data_panos_gex)
data_panos_gex <- gexp_normalize(data_panos_gex)
data_tabsap <- readRDS('Tabula_sapiens_data/Tabula_sapiens_bladder.rds')
data_tabsap_gex <- Seurat::GetAssayData(data_tabsap@assays$RNA, layer = 'counts')
data_tabsap_gex <- (data_tabsap_gex)[,sample(colnames(data_tabsap_gex),20000)]
data_tabsap_gex <- match_genesets(gex_norm,data_tabsap_gex)
data_tabsap_gex <- gexp_normalize(data_tabsap_gex)
combi <- Matrix::t(cbind((gex_norm)[,train_samples],(data_tabsap_gex)[,tabsap_samples]))
train_samples <- sample(colnames(gex_norm),1000)
panos_samples <- sample(colnames(data_panos_gex),1000)
tabsap_samples <- sample(colnames(data_tabsap_gex),1000)
train_samples <- sample(colnames(gex_norm),1000)
panos_samples <- sample(colnames(data_panos_gex),1000)
tabsap_samples <- sample(colnames(data_tabsap_gex),1000)
combi <- Matrix::t(cbind((gex_norm)[,train_samples],(data_tabsap_gex)[,tabsap_samples]))
umap_all <- uwot::umap(as.matrix(combi))
umap_pldf <- as.data.frame(cbind(umap_all,
dataset = c(rep('3TissueModel',1000),rep('Data Panos',1000),rep('TabSap', 1000)),
cell_type = c(rep('Unknown',1000),(data_panos@meta.data)[panos_samples,'CellType1'],as.character((data_tabsap@meta.data)[tabsap_samples,'compartment']))
))
umap_pldf$V1 <- as.numeric(umap_pldf$V1)
umap_pldf$V2 <- as.numeric(umap_pldf$V2)
library(ggplot2)
ggplot(umap_pldf,aes(x = V1, y = V2)) + geom_point(aes(colour = dataset, shape = cell_type))
View(combi)
