View(gex_test)
View(gex_test_normed)
View(gex_test)
View(gex_test_normed)
View(gex_test)
gex_test_normed_df <- data.frame(gex_test_normed)
View(gex_test_normed_df)
write.table(gex_test_normed_df,'3TModel_test_gex_normed.txt',sep = '\t')
