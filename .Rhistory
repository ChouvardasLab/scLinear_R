for(type in names(celltype_counts)){
samplesize <- min(celltype_counts[[type]],40000/length(celltype_counts))
keep <- c(keep,sample(colnames(Input_Seurat)[Input_Seurat@meta.data$cell_type == type],samplesize,replace = FALSE))
}
#Draw remaining cells from whatever is left
keep <- c(keep,sample(setdiff(colnames(Input_Seurat),keep),min(40000,ncol(Input_Seurat))-length(keep),replace = FALSE))
Input_Seurat <- (Input_Seurat)[,keep]
writexl::write_xlsx(Input_Seurat@meta.data,path = glue::glue('Summary_output_all_datasets/Metadata/{dataset_name}_metadata.xlsx'))
#Pre-normalize here to avoid problems with minimum cluster size
#Still keep the check for at least 200 cells later because we need a reasonable amount for
#tSVD and lm anyways
gex = Seurat::GetAssayData(Input_Seurat@assays[["RNA"]],layer = 'counts')
gex <- gexp_normalize(gex)
Input_Seurat[["RNA"]] <- Seurat::CreateAssayObject(gex)
rm(gex)
#Forgot to save excel with rownames during training --> use new annotation
#Might be the same since seed fixed?
metadata <- Input_Seurat@meta.data
valid_prot_comparisons <- protein_mapping[!is.na(protein_mapping[,dataset_name]),]
rownames(valid_prot_comparisons) <- valid_prot_comparisons$Consensus
datasets_to_apply <- setdiff(colnames(valid_prot_comparisons),c('Consensus',dataset_name))
for(ds_index in 1:length(datasets_to_apply)){
dataset <- datasets_to_apply[ds_index]
# Unspecific models -------------------------------------------------------
pretrained_model <- readRDS(glue::glue('Summary_output_all_datasets/Pretrained_models/{dataset}_based_model.rds'))
#Already prenormed
prediction <- predict(predictor = pretrained_model,gexp = Input_Seurat@assays$RNA@counts,normalize_gex = FALSE)
colnames(prediction) <- stringr::str_replace_all(colnames(prediction),'-','.')
mapping_list <- valid_prot_comparisons[!is.na(valid_prot_comparisons[,dataset]),] %>% select(Consensus,dataset)
# Handle alternative antibodies in later verison --> for now just take first
colnames(prediction) <- stringr::str_replace_all(colnames(prediction),' ','.')
prediction <- prediction[,mapping_list %>% pull(dataset)]
colnames(prediction) <- mapping_list %>% pull(Consensus)
true_adt <- log(Input_Seurat@assays$ADT$counts)
rownames(true_adt) <- stringr::str_replace_all(rownames(true_adt),'-','.')
rownames(true_adt) <- stringr::str_replace_all(rownames(true_adt),' ','.')
true_adt <- (true_adt)[valid_prot_comparisons[colnames(prediction),] %>% pull(dataset_name),]
rownames(true_adt) <- colnames(prediction)
grouping <- metadata$cell_type
plot_dir <- glue::glue('Cross_ds_auto/Pred_eval_plots/Preds_{dataset_name}/from_{dataset}/universal')
layers <- stringr::str_split(plot_dir,'/')[[1]]
for(layer in 1:length(layers)){
if(!dir.exists(stringr::str_flatten(layers[1:layer],collapse = '/'))){
dir.create(stringr::str_flatten(layers[1:layer],collapse = '/'))
}
}
for(prot in colnames(prediction)){
p <- plot_comparison((true_adt)[prot,],prediction[,prot],groupings = grouping) + xlab(glue::glue('True log({prot}) from {dataset_name}')) +
ylab(glue::glue('Predicted log({prot}) based on {dataset}')) + ggtitle(prot)
ggsave(glue::glue('{stringr::str_replace_all(prot," ","_")}_{dataset_name}_from_{dataset}.pdf'),p,path = plot_dir,
width = 8,height = 8)
}
# Cell_type_specific_models -----------------------------------------------
# Exclude models which were overfit/ had horrible performance even in their own dataset
ok_models <- model_performances_per_celltype %>% filter(RMSE < 1 | `Mean per prot pearson` > 0.3)
model_names <- stringr::str_match(ok_models$`Dataset name`,glue::glue('({dataset})_(.*)'))
colnames(model_names) <- c('full_name','base_dataset','cell_type')
model_names <- as.data.frame(model_names) %>% filter(!is.na(full_name))
for(modelnr in 1:nrow(model_names)){
model_name <- model_names[modelnr,"full_name"]
cell_type_filter <- model_names[modelnr,"cell_type"]
cells_to_consider <- rownames(metadata %>% filter(cell_type == cell_type_filter))
#next here for loop if no cells to consider
if(length(cells_to_consider)<50){next}
pretrained_model_type_specific <- readRDS(glue::glue('Summary_output_all_datasets_per_celltype/Pretrained_models/{model_name}_based_model.rds'))
prediction_cell_type_specific <- predict(pretrained_model_type_specific,(Input_Seurat@assays$RNA$counts)[,cells_to_consider],normalize_gex = FALSE)
colnames(prediction_cell_type_specific) <- stringr::str_replace_all(colnames(prediction_cell_type_specific),'-','.')
colnames(prediction_cell_type_specific) <- stringr::str_replace_all(colnames(prediction_cell_type_specific),' ','.')
prediction_cell_type_specific <- prediction_cell_type_specific[,mapping_list %>% pull(dataset)]
colnames(prediction_cell_type_specific) <- mapping_list %>% pull(Consensus)
true_adt_same_type <- (true_adt)[,cells_to_consider]
plot_dir <- glue::glue('Cross_ds_auto/Pred_eval_plots/Preds_{dataset_name}/from_{dataset}/cell_specific')
layers <- stringr::str_split(plot_dir,'/')[[1]]
for(layer in 1:length(layers)){
if(!dir.exists(stringr::str_flatten(layers[1:layer],collapse = '/'))){
dir.create(stringr::str_flatten(layers[1:layer],collapse = '/'))
}
}
for(prot in colnames(prediction_cell_type_specific)){
p <- plot_comparison((true_adt_same_type)[prot,],prediction_cell_type_specific[,prot]) + xlab(glue::glue('True log({prot}) from {dataset_name}')) +
ylab(glue::glue('Predicted log({prot}) based on {dataset}')) + ggtitle(glue::glue('{prot}_{cell_type_filter}'))
ggsave(glue::glue('{stringr::str_replace_all(prot," ","_")}_{cell_type_filter}_{dataset_name}_from_{dataset}.pdf'),p,path = plot_dir,
width = 8, height = 8)
}
}
}
rm(Input_Seurat)
}
