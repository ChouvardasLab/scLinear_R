install.packages('rcartocolor')
#reading seurat object with the cell type annotation in "CellType1"
obj <- readRDS("Bladder_seurat_from_Panos/annotated_seurat.rds")
#setting and ordering idents
Idents(obj) <- "CellType1"
Idents(obj) <- factor(obj@active.ident, sort(levels(obj@active.ident)))
#umap
DimPlot(obj, group.by = "CellType1", cols = rcartocolor::carto_pal(8, "Safe")[c(1,2,3,7)], label = T, label.box = T, label.color = "white") + theme(axis.text = element_blank(), axis.title = element_blank(), legend.position = "none") + ggtitle(paste0("N = ", ncol(obj), " cells"))
ggsave("../plots/UMAP.pdf", width = 10, height = 10, units = "cm")
DimPlot(obj, group.by = "CellType1", cols = rcartocolor::carto_pal(8, "Safe")[c(1,2,3,7)], label = T, label.box = T, label.color = "white") + theme(axis.text = element_blank(), axis.title = element_blank(), legend.position = "none") + ggtitle(paste0("N = ", ncol(obj), " cells"))
ggsave("Posterplots//UMAP.pdf", width = 10, height = 10, units = "cm")
ggsave("Posterplots//UMAP.png", width = 10, height = 10, units = "cm", dpi = 300)
#finding all marker genes, ordering factors and filtering
M <- FindAllMarkers(obj, only.pos = T, min.pct = 0.25)
M$cluster <- factor(M$cluster, sort(levels(M$cluster)))
Cell_Type_Markers <- filter(M, p_val_adj < 0.05)
#preparing color palette, change 10 to the number of top genes to show
color_y <- c(rep(rcartocolor::carto_pal(8, "Safe")[1], 10), rep(rcartocolor::carto_pal(8, "Safe")[2], 10),
rep(rcartocolor::carto_pal(8, "Safe")[3], 10), rep(rcartocolor::carto_pal(8, "Safe")[7],10))
#top gene markers; change n to the number of top genes to show
Top <- Cell_Type_Markers %>% group_by(cluster) %>% slice_max(order_by = avg_log2FC, n = 10)
#dotplot
DotPlot(object = obj, features = rev(Top$gene)) + theme(axis.text.y = element_text(color = rev(color_y))) + scale_color_gradientn(colours = carto_pal(11, "Geyser")) + coord_flip() + theme(axis.text.x = element_text(angle = 90, hjust = 1, size = 14)) + theme(axis.text.y = element_text(size=14, face = "bold")) + theme(axis.title.x = element_blank()) + theme(axis.title.y = element_blank())+ theme(legend.position = "none") + theme(axis.text.x = element_text( vjust = 0.5))
DotPlot(object = obj, features = rev(Top$gene)) + theme(axis.text.y = element_text(color = rev(color_y))) + scale_color_gradientn(colours = rcartocolor::carto_pal(11, "Geyser")) + coord_flip() + theme(axis.text.x = element_text(angle = 90, hjust = 1, size = 14)) + theme(axis.text.y = element_text(size=14, face = "bold")) + theme(axis.title.x = element_blank()) + theme(axis.title.y = element_blank())+ theme(legend.position = "none") + theme(axis.text.x = element_text( vjust = 0.5))
